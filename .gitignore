# ============================================
# Python 项目 .gitignore
# ============================================

# ------------------- Python -------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ------------------- 虚拟环境 -------------------
venv/
env/
ENV/
.venv

# ------------------- IDE -------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ------------------- 环境变量 & 敏感信息 -------------------
.env
.env.local
*.key
secrets/

# ------------------- 数据文件 -------------------
*.json
*.csv
*.xlsx
!requirements.txt
!package.json
!.env.example

# 允许的配置文件示例
longgraph/.env.example

# ------------------- 日志 -------------------
*.log
logs/

# ------------------- 输出文件 -------------------
douyin_data_tool/output/
longgraph/data/output/
longgraph/data/audio/
*.wav
*.mp3
*.mp4
*.avi

# ------------------- 临时文件 -------------------
nul
*.tmp
*.bak
*.cache
.pytest_cache/
.coverage
htmlcov/
python_services/temp/

# ------------------- OS -------------------
Thumbs.db
Desktop.ini
